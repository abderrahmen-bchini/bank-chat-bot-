# Environment variables template
# Copy to .env (do NOT commit .env)

# Flask
FLASK_SECRET_KEY=dev-secret-change-me

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Qdrant
# Local (Windows/macOS/Linux):
QDRANT_URL=http://127.0.0.1:6333
# or (alternative) host/port:
# QDRANT_HOST=127.0.0.1
# QDRANT_PORT=6333
# If using Qdrant Cloud:
# QDRANT_URL=https://xxxxxx.cloud.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key

# RAG config
COLLECTION_NAME=rag_collection
QDRANT_TIMEOUT_SECONDS=120
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_SIZE=384

# Groq (optional) — enables LLM answers grounded in retrieved chunks
# GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
